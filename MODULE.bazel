#### Kotlin/MVM/Android
build_constants = use_repo_rule("@rules_player//distribution:defs.bzl", "build_constants")

build_constants(
    name = "build_constants",
    constants = {
        "GROUP": "com.intuit.playerui.devtools",
    },
    version_file = "//:VERSION",
)

bazel_dep(name = "rules_jvm_external", version = "6.8")

# Override for AAR publishing support
git_override(
    module_name = "rules_jvm_external",
    # branch = "maven-export-aar-6.8",
    commit = "0dc1a97c0403de02e0bf9a03244212a15dae3333",
    remote = "https://github.com/sugarmanz/rules_jvm_external.git",
)

maven = use_extension("@rules_jvm_external//:extensions.bzl", "maven")
maven.from_toml(
    bom_modules = [
        "org.junit:junit-bom",
        "androidx.compose:compose-bom",
    ],
    libs_versions_toml = "//:libs.versions.toml",
)
maven.amend_artifact(
    coordinates = "com.intuit.playerui:testutils",
    exclusions = [
        "com.intuit.playerui:hermes",
    ],
)
maven.amend_artifact(
    coordinates = "com.facebook.flipper:flipper",
    exclusions = [
        # TODO: Try to override
        "com.android.ndk.thirdparty:openssl",
    ],
)
maven.install(
    fetch_sources = True,
    known_contributing_modules = [
        "bazel_worker_java",
        "devtools",
    ],
    lock_file = "//:maven-lock.json",
    repositories = [
        "https://repo1.maven.org/maven2",
        "https://maven.google.com/",
    ],
    version_conflict_policy = "pinned",
)

# maven.override(
#     name = "maven",
#     coordinates = "com.android.ndk.thirdparty:openssl",
#     target = "@maven//:com.android.ndk.thirdparty:openssl",
# )
use_repo(maven, "maven")

bazel_dep(name = "rules_kotlin", version = "2.1.8")

register_toolchains("//helpers:kotlin_toolchain")

