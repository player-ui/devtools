####### Node.js version #########
bazel_dep(name = "rules_nodejs", version = "6.4.0")

node = use_extension("@rules_nodejs//nodejs:extensions.bzl", "node")
node.toolchain(node_version = "22.15.1")
#################################

npm = use_extension("@aspect_rules_js//npm:extensions.bzl", "npm")
npm.npm_translate_lock(
    name = "npm",
    data = [
        "//:package.json",
    ],
    npm_package_target_name = "{dirname}",
    npmrc = "//:.npmrc",
    pnpm_lock = "//:pnpm-lock.yaml",
)
use_repo(npm, "npm")

rules_ts_ext = use_extension(
    "@aspect_rules_ts//ts:extensions.bzl",
    "ext",
    dev_dependency = True,
)
rules_ts_ext.deps(
    ts_version_from = "//:package.json",
)
use_repo(rules_ts_ext, "npm_typescript")
###### End node.js ######

###### Start iOS ######
## Rule Dependencies
bazel_dep(name = "rules_xcodeproj", version = "2.12.1")
bazel_dep(name = "rules_apple", version = "4.1.0", repo_name = "build_bazel_rules_apple")
bazel_dep(name = "apple_support", version = "1.22.0", repo_name = "build_bazel_apple_support")
bazel_dep(name = "rules_swift", version = "2.9.0")
bazel_dep(name = "rules_swift_package_manager", version = "1.3.0")
bazel_dep(name = "swiftlint", version = "0.59.1", repo_name = "SwiftLint")

## This section is handled by rules_swift_package_manager
swift_deps = use_extension(
    "@rules_swift_package_manager//:extensions.bzl",
    "swift_deps",
)
swift_deps.from_package(
    resolved = "//:ios/demo/Package.resolved",
    swift = "//:ios/demo/Package.swift",
)

# Run `bazel mod tidy` to update this list automatically.
# If it's not updating automatically, try deleting the MODULE.bazel.lock.
# If that doesn't work, you can add things manually.
# For example, if you use PlayerUI, you can add it like this:
# "swiftpkg_playerui_swift_package"
use_repo(
    swift_deps,
    "swift_package",  # Not sure what this is for, but it is required
    "swiftpkg_playerui_swift_package",
    "swiftpkg_swift_hooks",
    "swiftpkg_swiftflipper",
    "swiftpkg_swiftlint",
    "swiftpkg_viewinspector",
)

###### End iOS ######

